{
  "name": "@aptero/mesh-router-perf",
  "version": "1.0.0",
  "description": "Performance testing service for mesh-router infrastructure",
  "main": "dist/index.js",
  "type": "module",
  "private": false,
  "scripts": {
    "exec": "tsc && node dist/index.js",
    "build": "tsc",
    "start": "tsc-watch --onSuccess \"node ./dist/index.js\"",
    "test": "tsc && mocha dist/**/*.spec.js",
    "test-api": "bash test-api.sh",
    "lint": "eslint src --ext ts",
    "generate-data": "tsc && node dist/utils/generate-files.js"
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.3",
    "@fastify/websocket": "^11.0.2",
    "dotenv": "^17.2.3",
    "fastify": "^5.3.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/chai": "^5.2.2",
    "@types/mocha": "10.0.10",
    "@types/node": "^22.15.29",
    "@types/ws": "^8.18.1",
    "chai": "^5.2.0",
    "mocha": "11.7.5",
    "tsc-watch": "^6.2.1",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.9.0+sha512.60c18acd138bff695d339be6ad13f7e936eea6745660d4cc4a776d5247c540d0edee1a563695c183a66eb917ef88f2b4feb1fc25f32a7adcadc7aaf3438e99c1"
}
